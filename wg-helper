#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/.env"

BUILD_DIR="build"
WG_BASE_CONFIG_FILE="build/wg0.conf.base"
WG_PEER_DIR="build/wg0.conf.d"
WG_CONFIG_FILE="${SCRIPT_DIR}/wg0.conf"
SERVER_PRIVATE_KEY_FILE="build/server_privatekey"
SERVER_PUBLIC_KEY_FILE="build/server_publickey"
KEYS_DIR="build/client_keys"
CONFIGS_DIR="build/configs"
MAKEFILE="build/configs/Makefile"

assemble_wg_config() {
  [[ -f "${WG_BASE_CONFIG_FILE}" ]] || die "Missing file: ${WG_BASE_CONFIG_FILE}"
  mkdir -p "${WG_PEER_DIR}" "$(dirname "${WG_CONFIG_FILE}")"

  cp "${WG_BASE_CONFIG_FILE}" "${WG_CONFIG_FILE}"

  local fragment
  local has_fragment=0
  for fragment in "${WG_PEER_DIR}"/client_*.conf; do
    [[ -f "${fragment}" ]] || continue
    has_fragment=1
    break
  done

  ((has_fragment == 0)) && return

  printf '\n' >>"${WG_CONFIG_FILE}"
  for fragment in "${WG_PEER_DIR}"/client_*.conf; do
    [[ -f "${fragment}" ]] || continue
    cat "${fragment}" >>"${WG_CONFIG_FILE}"
    printf '\n' >>"${WG_CONFIG_FILE}"
  done
}

peer_fragment_file() {
  local idx="$1"
  printf '%s/client_%s.conf\n' "${WG_PEER_DIR}" "${idx}"
}

create_server_config() {
  require_wg

  local server_ip_value wg_device_name server_private_key server_public_key
  server_ip_value="$(server_ip)"

  wg_device_name="${WG_CONFIG_FILE##*/}"
  wg_device_name="${wg_device_name%.*}"

  mkdir -p "${BUILD_DIR}" "${WG_PEER_DIR}" "${KEYS_DIR}" "${CONFIGS_DIR}" "$(dirname "${WG_BASE_CONFIG_FILE}")" "$(dirname "${WG_CONFIG_FILE}")" "$(dirname "${MAKEFILE}")" "$(dirname "${SERVER_PRIVATE_KEY_FILE}")" "$(dirname "${SERVER_PUBLIC_KEY_FILE}")"

  server_private_key="$(wg genkey)"
  server_public_key="$(printf '%s' "${server_private_key}" | wg pubkey)"
  printf '%s\n' "${server_private_key}" >"${SERVER_PRIVATE_KEY_FILE}"
  printf '%s\n' "${server_public_key}" >"${SERVER_PUBLIC_KEY_FILE}"

  cat >"${WG_BASE_CONFIG_FILE}" <<EOF
[Interface]
Address = ${server_ip_value}/${WG_SERVER_CIDR}
ListenPort = ${WG_LISTEN_PORT}
PrivateKey = ${server_private_key}

PostUp   = sysctl -w net.ipv4.ip_forward=1
PostUp   = iptables -A FORWARD -i ${wg_device_name} -j ACCEPT; iptables -A FORWARD -o ${wg_device_name} -j ACCEPT; iptables -t nat -A POSTROUTING -o ${WG_INTERFACE} -j MASQUERADE
PostDown = iptables -D FORWARD -i ${wg_device_name} -j ACCEPT; iptables -D FORWARD -o ${wg_device_name} -j ACCEPT; iptables -t nat -D POSTROUTING -o ${WG_INTERFACE} -j MASQUERADE
EOF

  assemble_wg_config

  touch "${MAKEFILE}"
  printf 'Created server config: %s\n' "${WG_CONFIG_FILE}"
}

add_client() {
  local client_index="$1"

  require_wg
  [[ -f "${WG_BASE_CONFIG_FILE}" ]] || die "Missing file: ${WG_BASE_CONFIG_FILE}"

  mkdir -p "${KEYS_DIR}" "${CONFIGS_DIR}" "${WG_PEER_DIR}" "$(dirname "${MAKEFILE}")"

  local client_ip client_name client_fragment_file
  local client_private_key_file client_public_key_file client_config_file
  local client_private_key client_public_key server_public_key

  client_ip="$(client_ip_from_index "${client_index}")" || die "No valid client IP for index ${client_index}"
  ! client_exists "${client_index}" || die "Client index ${client_index} already exists"

  client_name="client_${client_index}"
  client_private_key_file="${KEYS_DIR}/${client_name}_privatekey"
  client_public_key_file="${KEYS_DIR}/${client_name}_publickey"
  client_config_file="${CONFIGS_DIR}/${client_name}.conf"
  client_fragment_file="$(peer_fragment_file "${client_index}")"

  client_private_key="$(wg genkey)"
  client_public_key="$(printf '%s' "${client_private_key}" | wg pubkey)"
  printf '%s\n' "${client_private_key}" >"${client_private_key_file}"
  printf '%s\n' "${client_public_key}" >"${client_public_key_file}"

  if [[ -f "${SERVER_PUBLIC_KEY_FILE}" ]]; then
    server_public_key="$(tr -d '\r\n' < "${SERVER_PUBLIC_KEY_FILE}")"
  else
    [[ -f "${SERVER_PRIVATE_KEY_FILE}" ]] || die "Missing file: ${SERVER_PRIVATE_KEY_FILE}"
    server_public_key="$(tr -d '\r\n' < "${SERVER_PRIVATE_KEY_FILE}" | wg pubkey)"
  fi

  cat >"${client_fragment_file}" <<EOF
[Peer]
PublicKey = ${client_public_key}
AllowedIPs = ${client_ip}/32
EOF

  assemble_wg_config

  cat >"${client_config_file}" <<EOF
[Interface]
Address = ${client_ip}/32
PrivateKey = ${client_private_key}
DNS = 8.8.8.8, 1.1.1.1

[Peer]
AllowedIPs = ${WG_CLIENT_ALLOWED_IPS}
Endpoint = ${WG_ENDPOINT}:${WG_LISTEN_PORT}
PersistentKeepalive = ${WG_PERSISTENT_KEEPALIVE}
PublicKey = ${server_public_key}
EOF

  touch "${MAKEFILE}"
  if ! grep -qE "^show_${client_index}:$" "${MAKEFILE}"; then
    {
      printf 'show_%s:\n' "${client_index}"
      printf '\tqrencode -t ansiutf8 -r client_%s.conf\n' "${client_index}"
    } >>"${MAKEFILE}"
  fi

  printf 'Created %s: %s\n' "${client_name}" "${client_ip}"
}

remove_client() {
  local client_index
  client_index="$(parse_index_arg remove_client "$@")"

  [[ -f "${WG_BASE_CONFIG_FILE}" ]] || die "Missing file: ${WG_BASE_CONFIG_FILE}"
  local client_ip tmp_makefile peer_file

  client_ip="$(client_ip_from_index "${client_index}")" || die "Index ${client_index} is invalid for mapping client_N => x.x.x.(N+1)"
  peer_file="$(peer_fragment_file "${client_index}")"
  [[ -f "${peer_file}" ]] || die "Missing peer fragment: ${peer_file}"
  rm -f "${peer_file}"

  assemble_wg_config

  for f in \
    "${KEYS_DIR}/client_${client_index}_publickey" \
    "${KEYS_DIR}/client_${client_index}_privatekey" \
    "${CONFIGS_DIR}/client_${client_index}.conf"; do
    [[ -f "${f}" ]] && rm -f "${f}"
  done

  if [[ -f "${MAKEFILE}" ]]; then
    tmp_makefile="$(mktemp)"
    awk -v idx="${client_index}" '
      BEGIN { skip=0 }
      $0 ~ "^show_" idx ":$" { skip=1; next }
      skip==1 && $0 ~ /^\tqrencode -t ansiutf8 -r client_[0-9]+\.conf$/ { skip=0; next }
      skip==1 && $0 ~ /^show_[0-9]+:$/ { skip=0; print; next }
      skip==1 && $0 ~ /^$/ { skip=0; next }
      { print }
    ' "${MAKEFILE}" >"${tmp_makefile}"
    mv "${tmp_makefile}" "${MAKEFILE}"
  fi

  printf 'Removed client_%s: %s\n' "${client_index}" "${client_ip}"
}

die() {
  printf '%s\n' "$1" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Usage:
  ./wg-helper create_server_config
  ./wg-helper add_client --index <N>
  ./wg-helper remove_client --index <N>
EOF
}

load_env() {
  [[ -f "${ENV_FILE}" ]] || die "Missing .env: ${ENV_FILE}"
  # shellcheck disable=SC1090
  source "${ENV_FILE}"

  : "${WG_BASE_IP:?Missing WG_BASE_IP in .env}"
  : "${WG_SERVER_CIDR:?Missing WG_SERVER_CIDR in .env}"
  : "${WG_LISTEN_PORT:?Missing WG_LISTEN_PORT in .env}"
  : "${WG_INTERFACE:?Missing WG_INTERFACE in .env}"
  : "${WG_ENDPOINT:?Missing WG_ENDPOINT in .env}"
  : "${WG_CLIENT_ALLOWED_IPS:?Missing WG_CLIENT_ALLOWED_IPS in .env}"
  : "${WG_PERSISTENT_KEEPALIVE:?Missing WG_PERSISTENT_KEEPALIVE in .env}"
}

server_ip() {
  printf '%s.1\n' "${WG_BASE_IP}"
}

client_ip_from_index() {
  local idx="$1"
  local last_octet

  [[ "${idx}" =~ ^[1-9][0-9]*$ ]] || return 1
  last_octet=$((idx + 1))
  ((last_octet >= 2 && last_octet <= 254)) || return 1

  printf '%s.%s\n' "${WG_BASE_IP}" "${last_octet}"
}

require_wg() {
  command -v wg >/dev/null 2>&1 || die "wg not found"
}

client_exists() {
  local idx="$1"
  local ip

  ip="$(client_ip_from_index "${idx}")" || return 1

  if [[ -f "${KEYS_DIR}/client_${idx}_privatekey" || -f "${KEYS_DIR}/client_${idx}_publickey" || -f "${CONFIGS_DIR}/client_${idx}.conf" || -f "$(peer_fragment_file "${idx}")" ]]; then
    return 0
  fi

  [[ -f "${WG_CONFIG_FILE}" ]] && grep -qE "^[[:space:]]*AllowedIPs[[:space:]]*=[[:space:]]*${ip}/32[[:space:]]*$" "${WG_CONFIG_FILE}"
}

parse_index_arg() {
  local action="$1"
  local flag="${2:-}"
  local value="${3:-}"

  [[ $# -eq 3 && "${flag}" == "--index" ]] || die "Usage: ./wg-helper ${action} --index <N>"
  [[ "${value}" =~ ^[1-9][0-9]*$ ]] || die "Index must be a positive integer"
  printf '%s\n' "${value}"
}

main() {
  load_env

  local command="${1:-}"
  case "${command}" in
    create_server_config)
      [[ $# -eq 1 ]] || die "Usage: ./wg-helper create_server_config"
      create_server_config
      ;;
    add_client)
      shift
      add_client "$(parse_index_arg add_client "$@")"
      ;;
    remove_client)
      shift
      remove_client "$@"
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}


main "$@"
